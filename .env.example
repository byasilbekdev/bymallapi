# Database (Supabase)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Redis (refresh token revocation store)
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret-min-32-characters-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-characters-long"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# App
PORT=3000
NODE_ENV=development
FRONTEND_URL="http://localhost:3001"
COOKIE_SECRET="change-me-cookie-secret-min-16-chars"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/api/v1/auth/google/callback"

# Email (Resend SMTP or any SMTP provider)
MAIL_HOST="smtp.resend.com"
MAIL_PORT=587
MAIL_USER="resend"
MAIL_PASSWORD=""
MAIL_FROM="no-reply@bymall.uz"
